            <xml-property name="queryText"><![CDATA[select aicrm_inspection.*,aicrm_building.building_name,aicrm_branch.branch_name,
aicrm_products.productname,aicrm_products.unit_size
from aicrm_inspection
inner Join aicrm_crmentity on aicrm_crmentity.crmid = aicrm_inspection.inspectionid
inner Join aicrm_branch on aicrm_branch.branchid = aicrm_inspection.branchid
inner Join aicrm_building on aicrm_building.buildingid = aicrm_inspection.buildingid
inner Join aicrm_products on aicrm_products.productid = aicrm_inspection.productid
where aicrm_crmentity.deleted = 0 and aicrm_inspection.inspectionid = ?]]></xml-property>
